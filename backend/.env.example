# Server Port Configuration
PORT=5000

# MongoDB Database Connection String
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>

# Node Environment (development, production)
NODE_ENV=development

# Frontend Client Origin URL (CORS)
CLIENT_URL=http://localhost:5173

# Cryptography Settings
BCRYPT_SALT_ROUNDS=10

# JSON Web Token secrets (generate strong random hashes)
ACCESS_TOKEN_SECRET=your_jwt_access_token_secret_hash_key
REFRESH_TOKEN_SECRET=your_jwt_refresh_token_secret_hash_key

# Token Expiry Settings
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# SMTP Mail Server Transport Details
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Sender Mail Account Credentials
EMAIL_USER=your_sender_email@gmail.com
EMAIL_PASS=your_app_specific_password_key
EMAIL_FROM_NAME=
